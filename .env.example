# ==========================================
# Axum API Bridge
# ==========================================

# SQLite 資料庫路徑
DATABASE_URL=sqlite:///data/sqlite/agent.db

# API Bridge 監聽 Port
PORT=8080

# Daemon 的位址（API Bridge 用來呼叫 Daemon）
# 本機開發: http://127.0.0.1:7456
# Docker:   http://host.docker.internal:7456
# 遠端:     http://<daemon-host-ip>:7456
DAEMON_URL=http://127.0.0.1:7456

# ==========================================
# Local Agent Daemon
# ==========================================

# Daemon 監聽 Port
DAEMON_PORT=7456

# Bridge 的對外 URL（Daemon 用來回呼 Bridge）
# 本機開發: http://127.0.0.1:8080
# 遠端/Domain: https://your-domain.com
BRIDGE_URL=http://127.0.0.1:8080

# ==========================================
# CLI 執行路徑（選填，不填則從 PATH 尋找）
# ==========================================

# AGY_CLI_PATH=agy
# OPENAI_CLI_PATH=openai
# COPILOT_CLI_PATH=copilot
# CLAUDE_CLI_PATH=claude
